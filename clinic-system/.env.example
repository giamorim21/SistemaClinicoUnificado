# Copie este arquivo para .env e ajuste os valores antes de subir o Docker.
# O .env nao deve ser commitado — ja esta no .gitignore.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres

# ── DDL: use 'create' apenas no primeiro start para criar o schema do zero.
# Troque para 'update' apos o primeiro start para preservar os dados.
DDL_AUTO=update

# ── JWT (troque por uma chave forte em producao) ──────────────────────────────
JWT_SECRET=dev-secret-please-change-32chars-minimum-123456

# ── Super-usuario global (Manager) criado em /api/auth/seed-manager ──────────
ADMIN_EMAIL=admin@scu.local
ADMIN_PASSWORD=Admin#123
ADMIN_NAME=Administrador SCU
ADMIN_CPF=00000000000
